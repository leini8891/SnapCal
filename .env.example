# Keep Email/password Auth enabled in Supabase. Do not enable Anonymous sign-in
# for the personal cloud flow.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Vision providers
OPENAI_API_KEY=
OPENAI_ANALYZE_MODEL=gpt-4.1-mini
GLM_API_KEY=
GLM_ANALYZE_MODEL=glm-4.6v-flashx
# Optional override if you use a compatible proxy or want to force one endpoint.
# If unset, SnapCal will try Z.AI general endpoint first, then coding endpoint.
GLM_API_BASE_URL=
